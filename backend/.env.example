# =====================================================
# IntelliICU Backend
# =====================================================

PROJECT_NAME=IntelliICU Backend
PROJECT_VERSION=1.0.0
PROJECT_DESCRIPTION=Enterprise AI Clinical Decision Support Platform

# =====================================================
# Database
# =====================================================

DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=intelliicu
DATABASE_USER=postgres
DATABASE_PASSWORD=YOUR_SECURE_PASSWORD

# Optional: Use this for cloud deployments (Render/Neon)
DATABASE_URL=

# =====================================================
# Application
# =====================================================

DEBUG=False

# =====================================================
# Authentication
# =====================================================

AUTH_SECRET_KEY=GENERATE_A_LONG_RANDOM_SECRET_KEY
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# =====================================================
# AI Provider
# =====================================================

AI_PROVIDER=mock

# Supported Providers:
# mock
# openai
# gemini
# ollama
# lmstudio

# =====================================================
# OpenAI
# =====================================================

OPENAI_API_KEY=

# =====================================================
# Google Gemini
# =====================================================

GEMINI_API_KEY=

# =====================================================
# Ollama
# =====================================================

OLLAMA_BASE_URL=http://localhost:11434

# =====================================================
# LM Studio
# =====================================================

LMSTUDIO_BASE_URL=http://localhost:1234/v1

# =====================================================
# CORS
# =====================================================

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174