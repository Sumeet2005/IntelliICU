# ---------------------------------------------------------------------------
# IntelliICU CDSS - Deployment Environment Configuration
# Copy this file to .env and customize values for production deployment
# ---------------------------------------------------------------------------

# Project Metadata
PROJECT_NAME="IntelliICU Backend"
PROJECT_VERSION="1.0.0"
PROJECT_DESCRIPTION="Enterprise AI Clinical Decision Support Platform"

# PostgreSQL Configuration
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=intelliicu
DATABASE_USER=postgres
DATABASE_PASSWORD=YOUR_SECURE_PRODUCTION_DB_PASSWORD

# Security & Session Authentication (JWT)
# Generate a secure 32-character hexadecimal key in production via: openssl rand -hex 32
AUTH_SECRET_KEY=YOUR_SECURE_PRODUCTION_JWT_SECRET_KEY
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# Clinical AI LLM Provider Configuration
# Supported options: mock, ollama, lmstudio, openai, gemini
CLINICAL_LLM_PROVIDER=mock
CLINICAL_LLM_MODEL=mock-model
CLINICAL_LLM_TEMPERATURE=0.2
CLINICAL_LLM_MAX_TOKENS=1024
CLINICAL_LLM_STREAMING=true

# Ollama Endpoint Configuration (if provider = ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# LM Studio Endpoint Configuration (if provider = lmstudio)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# OpenAI API Key (if provider = openai)
OPENAI_API_KEY=your-openai-api-key-here

# Gemini API Key (if provider = gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# General Deployment Flag
DEBUG=False
